# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is gitignored and must NEVER be committed.

# SMTP credentials (Office365)
smtp_sender = "greetings@yourcompany.com"
smtp_password = "your-smtp-password"

# withoutbg API key (https://withoutbg.com)
withoutbg_api_key = "your-withoutbg-api-key"

# ZingHR client secret (only needed when data_source.mode = "zinghr")
zinghr_client_secret = "your-zinghr-secret"
# HR API auth header value (if your employee JSON endpoint requires authentication).
# Use this instead of storing the token in template_config.json.
# The header name (e.g. "Authorization") is still configured in the UI.
api_auth_header_value = "Bearer your-api-token"
